# App
APP_ENV=dev

# Database (Postgres + pgvector)
DATABASE_URL=postgresql+asyncpg://docintel:docintel@localhost:5432/docintel

# LLM
LLM_API_KEY=isi_groq_api_key
LLM_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq

# Embedding (Jina v3, 1024-dim)
EMBEDDING_PROVIDER=jina
EMBEDDING_API_KEY=isi_jina_api_key
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIM=1024

# Reranker (Cohere, default ON)
RERANK_ENABLED=true
COHERE_API_KEY=isi_cohere_api_key
RETRIEVE_TOP_K=30
RERANK_TOP_N=5
RERANK_TIMEOUT_S=5

# Retrieval
RETRIEVAL_MODE=hybrid

# Security / CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
API_KEY=set-ini-pas-deploy
RATE_LIMIT_PER_MIN=0

# Upload
UPLOAD_DIR=data/uploads
MAX_UPLOAD_MB=25
MAX_BATCH_FILES=20

# Eval (offline)
EVAL_JUDGE_MODEL=openai/gpt-oss-120b

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Vision
VISION_ENABLED=true
VISION_BASE_URL=https://api.groq.com/openai/v1
VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
VISION_MAX_IMAGES=10
VISION_MIN_IMAGE_KB=20
VISION_TIMEOUT_S=30

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64
