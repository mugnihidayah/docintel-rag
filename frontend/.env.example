# Absolute backend URL for split deploys (e.g. Vercel). Leave empty for local dev /
# docker-compose (relative paths via the dev/nginx proxy).
# Example: https://your-space.hf.space
VITE_API_BASE=

# Optional: only needed when the backend enforces an API key (API_KEY set in backend).
# Sent as the X-API-Key header on document upload/delete. Leave unset in local dev.
VITE_API_KEY=
